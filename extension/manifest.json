{
  "manifest_version": 2,
  "name": "Browseye",
  "version": "1.0.0",
  "description": "Full browser control via WebSocket — tab management, DOM manipulation, data extraction, network interception.",
  "author": "ENI",

  "permissions": [
    "<all_urls>",
    "tabs",
    "activeTab",
    "cookies",
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "downloads",
    "history",
    "storage",
    "unlimitedStorage",
    "clipboardRead",
    "clipboardWrite",
    "notifications",
    "sessions"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Browseye",
    "default_icon": "icons/icon.svg"
  },

  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },

  "applications": {
    "gecko": {
      "id": "browseye@eni.lo",
      "strict_min_version": "91.0"
    }
  }
}
